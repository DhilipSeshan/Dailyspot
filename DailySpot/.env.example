# Turso Database (get these from https://turso.tech after creating a database)
TURSO_DATABASE_URL=libsql://your-database-name-your-username.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Session secret (use a long random string in production)
SESSION_SECRET=change-this-to-a-random-secret-string

# Admin credentials (used for /ds-admin-9x7k/login)
ADMIN_EMAIL=admin@dailyspot.com
ADMIN_PASSWORD=Admin@1234

# App environment
NODE_ENV=development
PORT=3000
