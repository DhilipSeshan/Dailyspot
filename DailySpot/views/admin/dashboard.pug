extends layout

block content
  h2.admin-title Dashboard
  .stats-grid
    .stat-card
      p.stat-label Total Products
      p.stat-value= totalProducts
    .stat-card
      p.stat-label Total Orders
      p.stat-value= totalOrders
    .stat-card
      p.stat-label Registered Users
      p.stat-value= totalUsers
    .stat-card
      p.stat-label Total Revenue
      p.stat-value $#{revenue}
  h3(style='font-size:1.1rem; font-weight:600; margin-bottom:16px;') Recent Orders
  if recentOrders && recentOrders.length
    table.admin-table
      thead
        tr
          th Order #
          th Customer
          th Total
          th Status
          th Date
      tbody
        each o in recentOrders
          tr
            td ##{o.id}
            td= o.user_name || o.full_name
            td $#{parseFloat(o.total_amount).toFixed(2)}
            td
              span.status-badge(class='status-' + o.status)= o.status
            td= new Date(o.created_at).toLocaleDateString()
  else
    p(style='color:var(--text-muted);') No orders yet.
