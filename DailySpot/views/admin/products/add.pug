extends ../layout

block content
  .admin-card
    h2 Add New Product
    form(action='/ds-admin-9x7k/products/add', method='POST')
      .form-group
        label Product Name
        input.form-control(type='text', name='name', required, placeholder='e.g. Red Apple')
      .form-group
        label Description
        textarea.form-control(name='description', rows='3', placeholder='Describe the fruit...')
      .form-group
        label Price ($)
        input.form-control(type='number', name='price', step='0.01', min='0', required, placeholder='2.99')
      .form-group
        label Image URL
        input.form-control(type='url', name='image_url', placeholder='https://...')
      .form-group
        label Category
        select.form-control(name='category_id')
          option(value='') -- Select Category --
          each cat in categories
            option(value=cat.id)= cat.name
      .form-group
        label Stock Quantity
        input.form-control(type='number', name='stock', min='0', value='0')
      .form-group
        label
          input(type='checkbox', name='featured', style='margin-right:8px;')
          | Mark as Featured (shown on home page)
      .admin-actions
        button.btn.btn-green(type='submit') Add Product
        a.btn(href='/ds-admin-9x7k/products', style='background:var(--border); margin-left:8px; padding:12px 28px; border-radius:8px;') Cancel
