extends ../layout

block content
  .admin-card
    h2 Edit Product
    form(action='/ds-admin-9x7k/products/' + product.id + '/edit', method='POST')
      .form-group
        label Product Name
        input.form-control(type='text', name='name', required, value=product.name)
      .form-group
        label Description
        textarea.form-control(name='description', rows='3')= product.description
      .form-group
        label Price ($)
        input.form-control(type='number', name='price', step='0.01', min='0', required, value=product.price)
      .form-group
        label Image URL
        input.form-control(type='url', name='image_url', value=product.image_url)
      .form-group
        label Category
        select.form-control(name='category_id')
          option(value='') -- Select Category --
          each cat in categories
            option(value=cat.id, selected=(cat.id == product.category_id))= cat.name
      .form-group
        label Stock Quantity
        input.form-control(type='number', name='stock', min='0', value=product.stock)
      .form-group
        label
          input(type='checkbox', name='featured', style='margin-right:8px;', checked=(product.featured == 1))
          | Mark as Featured
      .admin-actions
        button.btn.btn-green(type='submit') Save Changes
        a.btn(href='/ds-admin-9x7k/products', style='background:var(--border); margin-left:8px; padding:12px 28px; border-radius:8px;') Cancel
