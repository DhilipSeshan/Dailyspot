extends ../layout

block content
  .orders-page
    a(href='/orders', style='color:var(--text-muted); font-size:.9rem; display:inline-block; margin-bottom:20px;') Back to My Orders
    h1(style='margin-bottom:24px;') Order ##{order.id}
    .order-box(style='background:var(--white); border-radius:12px; box-shadow:var(--shadow); padding:24px;')
      .order-meta
        p Order ID: ##{order.id}
        p Name: #{order.full_name}
        p Phone: #{order.phone}
        p Address: #{order.address}
        p
          | Status:
          span.status-badge(class='status-' + order.status)  #{order.status}
        p Total: $#{parseFloat(order.total_amount).toFixed(2)}
      h4(style='margin-top:20px; margin-bottom:12px;') Items
      each item in order.items
        .summary-row(style='display:flex; justify-content:space-between; font-size:.9rem; margin-bottom:6px;')
          span #{item.product_name} x #{item.quantity}
          span $#{(item.price * item.quantity).toFixed(2)}
